[Unit]
Description=Arena Watcher Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/arena-watcher/current
EnvironmentFile=/root/arena-watcher/config/arena-watcher.env
ExecStart=/usr/bin/dotnet /root/arena-watcher/current/DiscordBot.dll
Restart=always
RestartSec=15
KillSignal=SIGTERM
TimeoutStopSec=30
SyslogIdentifier=arena-watcher

[Install]
WantedBy=multi-user.target
